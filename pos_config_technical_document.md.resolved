    H -->|"Valid"| K["Set loading = true"]
    K --> L["POST /api/pos/configs { name }"]
    L --> M{"Server response"}
    M -->|"Error"| N["Show server error message"]
    M -->|"201 Success"| O["onCreated(config) callback"]
    O --> P["Add to configs array"]
    O --> Q["Select new config"]
    O --> R["Close modal"]
    O --> S["Toast success"]

    style A fill:#FFF7ED,stroke:#F97316
