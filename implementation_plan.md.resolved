## 🗄️ DATABASE SCHEMA

### Users Collection
```javascript
{
  name: String,
  email: String (unique),
  password: String (hashed),
  role: String ('admin' | 'staff'),
  createdAt: Date
}
```

### Products Collection
```javascript
{
  name: String,
  category: String ('Pizza' | 'Pasta' | 'Burger' | 'Coffee' | 'Beverages'),
  price: Number,
  unit: String,
  tax: Number (percentage),
  description: String,
  image: String,
  variants: [{
    attribute: String,    // e.g., "Pack"
    values: [{
      label: String,      // e.g., "6 items"
      extraPrice: Number  //  e.g., 50
    }]
  }],
  isActive: Boolean,
  sendToKitchen: Boolean,
  createdAt: Date
}
```

### Floors Collection
```javascript
{
  name: String,           // e.g., "Ground Floor"
  tables: [{
    tableNumber: Number,
    seats: Number,
    isActive: Boolean,
    status: String ('available' | 'occupied' | 'reserved'),
    currentOrder: ObjectId (ref: Order)
  }],
  createdAt: Date
}
```

### Sessions Collection
```javascript
{
  user: ObjectId (ref: User),
  openedAt: Date,
  closedAt: Date,
  status: String ('open' | 'closed'),
  totalSales: Number,
  orderCount: Number,
  closingSaleAmount: Number
}
```

### Orders Collection
```javascript
{
  orderNumber: String (auto-generated),
  session: ObjectId (ref: Session),
  table: { floor: ObjectId, tableNumber: Number },
  items: [{
    product: ObjectId (ref: Product),
    name: String,
    quantity: Number,
    price: Number,
    variant: String,
    notes: String
  }],
  subtotal: Number,
  tax: Number,
  total: Number,
  status: String ('draft' | 'sent' | 'preparing' | 'completed' | 'paid'),
  kitchenStatus: String ('to_cook' | 'preparing' | 'completed'),
  paymentMethod: String ('cash' | 'digital' | 'upi'),
  paymentStatus: String ('unpaid' | 'paid'),
  selfOrder: Boolean,
  selfOrderToken: String,
  createdBy: ObjectId (ref: User),
  createdAt: Date,
  paidAt: Date
}
```

### PaymentMethods Collection
```javascript
{
  user: ObjectId (ref: User),
  cash: { enabled: Boolean },
  digital: { enabled: Boolean },
  upi: { enabled: Boolean, upiId: String }
}
```

