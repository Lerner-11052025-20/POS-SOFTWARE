## 8. Critical Functions & Implementation

### 8.1 Password Hashing — `pre('save')` Hook

```javascript
// server/models/User.js — Lines 83-93
// CRITICAL: Runs automatically before every User.save()
userSchema.pre('save', async function (next) {
  if (!this.isModified('password')) return next(); // Skip if password unchanged
  try {
    const salt = await bcrypt.genSalt(12);         // 12 rounds = ~250ms on average CPU
    this.password = await bcrypt.hash(this.password, salt);
    next();
  } catch (err) {
    next(err);
  }
});
```

> [!IMPORTANT]
> **Salt Rounds = 12** — This is higher than the common default of 10. Each additional round doubles the computation time. 12 rounds provide ~250ms hash time, which is the recommended security/performance balance for production systems.

### 8.2 JWT Token Generation

```javascript
// server/models/User.js — Lines 101-111
userSchema.methods.generateToken = function () {
  return jwt.sign(
    {
      id: this._id,      // MongoDB document ID
      role: this.role,    // RBAC role
      email: this.email,  // User identifier
    },
    process.env.JWT_SECRET,
    { expiresIn: process.env.JWT_EXPIRE || '7d' }
  );
};
```

**JWT Payload Structure:**

| Claim | Value | Purpose |
|-------|-------|---------|
| `id` | MongoDB `_id` | User identification |
| `role` | `cashier\|kitchen\|customer\|manager` | Frontend route guard |
| `email` | User email | Backend identification |
| `iat` | Unix timestamp (auto) | Token issued time |
| `exp` | iat + 7 days (auto) | Token expiration |

### 8.3 Dual-Layer Token Response

```javascript
// server/routes/auth.js — Lines 8-29
const sendTokenResponse = (user, statusCode, res) => {
  const token = user.generateToken();

  const cookieOptions = {
    expires: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000), // 7 days
    httpOnly: true,      // ← Prevents XSS access to cookie
    secure: process.env.NODE_ENV === 'production',  // ← HTTPS only in prod
    sameSite: 'lax',     // ← CSRF protection
  };

  res
    .status(statusCode)
    .cookie('token', token, cookieOptions)  // Layer 1: httpOnly cookie
    .json({
      success: true,
      token,               // Layer 2: JSON response for localStorage
      user: user.toSafeObject(),
    });
};
```

### 8.4 Route Protection Middleware

```javascript
// server/middleware/auth.js — Lines 4-48
const protect = async (req, res, next) => {
  let token;

  // Priority 1: Authorization header (Bearer token)
  if (req.headers.authorization?.startsWith('Bearer')) {
    token = req.headers.authorization.split(' ')[1];
  }
  // Priority 2: httpOnly cookie
  else if (req.cookies?.token) {
    token = req.cookies.token;
  }

  if (!token) return res.status(401).json({ message: 'No token provided' });

  const decoded = jwt.verify(token, process.env.JWT_SECRET);
  req.user = await User.findById(decoded.id);

  if (!req.user) return res.status(401).json({ message: 'User not found' });
  if (!req.user.isActive) return res.status(403).json({ message: 'Account deactivated' });

  next();
};
```

### 8.5 Role Authorization Middleware

```javascript
// server/middleware/auth.js — Lines 51-62
const authorize = (...roles) => {
  return (req, res, next) => {
    if (!roles.includes(req.user.role)) {
      return res.status(403).json({
        message: `Role '${req.user.role}' is not authorized`
      });
    }
    next();
  };
};

// Usage example:
router.get('/admin-only', protect, authorize('manager'), handler);
```

### 8.6 Password Strength Calculator

```javascript
// client/src/utils/validation.js — Lines 2-21
export function getPasswordStrength(password) {
  let score = 0;
  const checks = {
    length:     password.length >= 8,      // +1
    lowercase:  /[a-z]/.test(password),     // +1
    uppercase:  /[A-Z]/.test(password),     // +1
    numbers:    /[0-9]/.test(password),     // +1
    special:    /[^A-Za-z0-9]/.test(password),  // +1
    longEnough: password.length >= 12,      // +1 (bonus)
  };

  // Score 0-6 maps to: Weak → Fair → Good → Strong → Excellent
  // Returns: { score, label, color, percent }
}
```

**Strength Levels:**

| Score | Label | Color | Bar % | Criteria Met |
|:-----:|-------|-------|:-----:|-------------|
| 0-2 | Weak | Red | 20% | ≤2 checks passed |
| 3 | Fair | Amber | 40% | 3 checks |
| 4 | Good | Yellow | 65% | 4 checks |
| 5 | Strong | Emerald | 85% | 5 checks |
| 6 | Excellent | Emerald | 100% | All 6 checks |

### 8.7 Axios Interceptor — Auto Token Attachment

```javascript
// client/src/services/api.js — Lines 12-23
api.interceptors.request.use((config) => {
  const token = localStorage.getItem('pos_token');
  if (token) {
    config.headers.Authorization = `Bearer ${token}`;
  }
  return config;
});

api.interceptors.response.use(
  (response) => response,
  (error) => {
    if (error.response?.status === 401) {
      localStorage.removeItem('pos_token');
      localStorage.removeItem('pos_user');
      if (!['/login', '/signup'].includes(window.location.pathname)) {
        window.location.href = '/login';
      }
    }
    return Promise.reject(error);
  }
);
```

